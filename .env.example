SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
# Optional newer Supabase name. If set, Netlify uses this instead of SUPABASE_ANON_KEY.
# SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key
# Optional until the n8n backend is ready. Leads still save to Supabase without it.
# N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/autolancer-lead

# Optional pipeline and local orchestration variables used as the backend build progresses.
# N8N_BASE_URL=https://your-n8n-instance.example.com
# N8N_API_KEY=your_n8n_api_key

# Optional future Qwen AI configuration from the AutoLancer build roadmap.
# QWEN_API_KEY=your_qwen_api_key
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus
